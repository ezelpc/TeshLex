apiVersion: v1
kind: Secret
metadata:
  name: teshlex-backend-secrets
  namespace: default
type: Opaque
# INSTRUCCIONES: No escribir valores aquí
# Crear con el comando:
#
# kubectl create secret generic teshlex-backend-secrets \
#   --from-literal=DATABASE_URL="postgresql://..." \
#   --from-literal=JWT_ACCESS_SECRET="..." \
#   --from-literal=JWT_REFRESH_SECRET="..." \
#   --from-literal=RESEND_API_KEY="..." \
#   --from-literal=MERCADOPAGO_ACCESS_TOKEN="..." \
#   --from-literal=MERCADOPAGO_WEBHOOK_SECRET="..." \
#   --from-literal=FRONTEND_URL="https://tu-dominio.ddns.net" \
#   --from-literal=BACKEND_URL="https://tu-dominio.ddns.net" \
#   --from-literal=CORS_ORIGINS="https://tu-dominio.ddns.net"
#
# Verificar: kubectl get secret teshlex-backend-secrets -o jsonpath='{.data}' | base64 -d
