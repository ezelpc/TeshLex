# ============================================================
# TeshLex Backend — Variables de Entorno
# COPIAR a .env y rellenar con valores reales
# NUNCA subir .env al repositorio
# ============================================================

# Base de datos
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/tesh_db

# JWT — Generar con: openssl rand -hex 64
JWT_ACCESS_SECRET=CAMBIAR_POR_SECRET_SEGURO_64_CHARS
JWT_REFRESH_SECRET=CAMBIAR_POR_OTRO_SECRET_SEGURO_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (Resend)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=noreply@tesh.edu.mx
EMAIL_FROM_NAME=TESH — Cursos de Idiomas

# Frontend (para CORS y back_urls de MP)
FRONTEND_URL=https://tu-dominio.ddns.net
BACKEND_URL=https://tu-dominio.ddns.net

# MercadoPago
# Obtener en: https://www.mercadopago.com.mx/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=TEST-XXXXXXXXXXXXXXXX
# Generar con: openssl rand -hex 32
MERCADOPAGO_WEBHOOK_SECRET=CAMBIAR_POR_SECRET_GENERADO_CON_OPENSSL
MERCADOPAGO_TEST_EMAIL=test_user@testuser.com

# Servidor
PORT=3000
NODE_ENV=production

# CORS (separar múltiples orígenes con coma)
CORS_ORIGINS=https://tu-dominio.ddns.net
